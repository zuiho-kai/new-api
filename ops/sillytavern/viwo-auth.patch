+        created: existing?.created || Date.now(),
+        password: '',
+        salt: '',
+        enabled: existing?.enabled ?? true,
+        admin: isNewApiAdmin(authUser.role),
+        externalAuth: 'new-api',
+        externalId: String(authUser.id),
+        externalUsername: authUser.username,
+        externalGroup: authUser.group,
+        externalSyncedAt: Date.now(),
+    };
+
+    await storage.setItem(key, user);
+
+    if (!existing) {
+        console.info('Creating data directories for external user', user.handle);
+        await ensurePublicDirectoriesExist();
+        await checkForNewContent([getUserDirectories(user.handle)], [CONTENT_TYPES.SETTINGS]);
+    }
+
+    return user;
+}
+
+async function tryNewApiLogin(handle, password) {
+    if (!NEW_API_AUTH_ENABLED) {
+        return null;
+    }
+
+    const auth = await validateNewApiLogin(handle, password);
+    if (!auth.ok) {
+        return { ok: false, error: auth.error || 'Incorrect credentials' };
+    }
+
+    const user = await upsertNewApiUser(auth.user);
+    return { ok: true, user };
+}
