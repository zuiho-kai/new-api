+function normalizeCustomOpenAIUrl(apiUrl) {
+    try {
+        const url = new URL(String(apiUrl || '').trim());
+        url.pathname = url.pathname.replace(/\/+$/, '');
+        url.search = '';
+        url.hash = '';
+        return url;
+    } catch {
+        return null;
+    }
+}
+
+function getCustomOpenAIBaseUrl(apiUrl) {
+    const url = normalizeCustomOpenAIUrl(apiUrl);
+
+    if (!url) {
+        return trimTrailingSlash(String(apiUrl || ''));
+    }
+
+    for (const suffix of OPENAI_COMPATIBLE_ENDPOINT_SUFFIXES) {
+        if (url.pathname.endsWith(suffix)) {
+            url.pathname = url.pathname.slice(0, -suffix.length) || '/';
+            break;
+        }
+    }
+
+    return `${url.origin}${url.pathname.replace(/\/+$/, '')}`;
+}
+
+function getCustomOpenAICompletionUrl(apiUrl, isTextCompletion) {
+    const url = normalizeCustomOpenAIUrl(apiUrl);
+
+    if (url && OPENAI_COMPATIBLE_ENDPOINT_SUFFIXES.some(suffix => url.pathname.endsWith(suffix))) {
+        return `${url.origin}${url.pathname}`;
+    }
+
+    const baseUrl = getCustomOpenAIBaseUrl(apiUrl);
+    return isTextCompletion ? urlJoin(baseUrl, '/completions') : urlJoin(baseUrl, '/chat/completions');
+}
 
