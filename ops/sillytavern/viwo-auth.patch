diff --git a/src/external-auth/new-api.js b/src/external-auth/new-api.js
new file mode 100644
index 0000000..753006f
--- /dev/null
+++ b/src/external-auth/new-api.js
@@ -0,0 +1,82 @@
+import process from 'node:process';
+
+const TRUE_VALUES = new Set(['1', 'true', 'yes', 'on']);
+const DEFAULT_LOGIN_URL = 'http://new-api:3000/api/user/login';
+const DEFAULT_TIMEOUT_MS = 8000;
+
+export const NEW_API_AUTH_ENABLED = TRUE_VALUES.has(String(process.env.SILLYTAVERN_NEW_API_AUTH_ENABLED ?? '').toLowerCase());
+
+function getLoginUrl() {
+    return String(process.env.SILLYTAVERN_NEW_API_LOGIN_URL || DEFAULT_LOGIN_URL);
+}
+
+function getTimeoutMs() {
+    const value = Number(process.env.SILLYTAVERN_NEW_API_AUTH_TIMEOUT_MS || DEFAULT_TIMEOUT_MS);
+    return Number.isFinite(value) && value > 0 ? value : DEFAULT_TIMEOUT_MS;
+}
+
+export function isNewApiAdmin(role) {
+    return Number(role) >= 10;
+}
+
+export async function validateNewApiLogin(username, password) {
+    if (!NEW_API_AUTH_ENABLED) {
+        return { ok: false, error: 'New API auth is disabled' };
+    }
+
+    if (!username || !password) {
+        return { ok: false, error: 'Missing credentials' };
+    }
+
+    const controller = new AbortController();
+    const timeout = setTimeout(() => controller.abort(), getTimeoutMs());
+
+    try {
+        const response = await fetch(getLoginUrl(), {
+            method: 'POST',
+            headers: { 'Content-Type': 'application/json' },
+            body: JSON.stringify({ username, password }),
+            signal: controller.signal,
+        });
+
+        let payload = null;
+        try {
+            payload = await response.json();
+        } catch {
+            payload = null;
+        }
+
+        if (!response.ok || !payload?.success) {
+            if (payload?.data?.require_2fa) {
+                return { ok: false, error: '2FA accounts are not supported by the SillyTavern bridge yet' };
+            }
+            return { ok: false, error: payload?.message || 'Incorrect credentials' };
+        }
+
+        if (payload?.data?.require_2fa) {
+            return { ok: false, error: '2FA accounts are not supported by the SillyTavern bridge yet' };
+        }
+
+        const data = payload.data || {};
+        if (!data.id || !data.username) {
+            return { ok: false, error: 'Invalid New API login response' };
+        }
+
+        return {
+            ok: true,
+            user: {
+                id: data.id,
+                username: String(data.username),
+                displayName: String(data.display_name || data.username),
+                role: Number(data.role || 1),
+                status: Number(data.status || 1),
+                group: String(data.group || 'default'),
+            },
+        };
+    } catch (error) {
+        const message = error?.name === 'AbortError' ? 'New API login timed out' : String(error?.message || error);
+        return { ok: false, error: message };
+    } finally {
+        clearTimeout(timeout);
+    }
+}
