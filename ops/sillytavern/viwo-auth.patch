+    try {
+        return JSON.parse(localStorage.getItem(SAVED_LOGIN_KEY) || '{}');
+    } catch {
+        return {};
+    }
+}
+
+function saveLoginPreference(handle, password) {
+    const remember = $('#rememberLogin').prop('checked');
+    const autoLogin = remember && $('#autoLogin').prop('checked');
+
+    if (!remember) {
+        localStorage.removeItem(SAVED_LOGIN_KEY);
+        return;
+    }
+
+    localStorage.setItem(SAVED_LOGIN_KEY, JSON.stringify({ handle, password, remember, autoLogin }));
+}
+
+function applySavedLogin() {
+    const saved = getSavedLogin();
+
+    if (saved.handle) {
+        $('#userHandle').val(saved.handle);
+    }
+    if (saved.password) {
+        $('#userPassword').val(saved.password);
+    }
+
+    $('#rememberLogin').prop('checked', Boolean(saved.remember));
+    $('#autoLogin').prop('checked', Boolean(saved.autoLogin));
+}
+
+function shouldAutoLogin() {
+    const saved = getSavedLogin();
+    const currentUrl = new URL(window.location.href);
+    return !currentUrl.searchParams.has('noauto') && saved.autoLogin && saved.handle && saved.password;
+}
 
